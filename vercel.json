{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "*.png", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Powered-By", "value": "" },
        { "key": "Server", "value": "" },
        { "key": "x-vercel-id", "value": "" },
        { "key": "x-vercel-cache", "value": "" }
      ]
    }
  ]
}
